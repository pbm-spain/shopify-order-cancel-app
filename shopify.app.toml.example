client_id = "YOUR_APP_CLIENT_ID"
name = "order-cancel-confirmation"
application_url = "https://your-app.example.com"
embedded = true
handle = "order-cancel-confirmation"

[access_scopes]
scopes = "write_orders,read_orders,write_app_proxy"

[auth]
redirect_urls = [
  "https://your-app.example.com/auth/callback",
  "https://your-app.example.com/auth/shopify/callback",
  "https://your-app.example.com/api/auth/callback"
]

[app_proxy]
url = "/proxy"
prefix = "apps"
subpath = "order-cancel"

# Admin link extension: Adds a link to the order details action menu
# The extension is defined in extensions/admin-link/shopify.extension.toml
# Once deployed, store owners will see "Order Cancellation Settings" link in the
# More actions menu on the Shopify order details page, linking to the admin dashboard
