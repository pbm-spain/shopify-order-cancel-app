PORT=3000
APP_BASE_URL=https://your-app.example.com
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_ADMIN_API_VERSION=2026-01
SHOPIFY_ADMIN_ACCESS_TOKEN=shpat_xxx
SHOPIFY_APP_PROXY_SHARED_SECRET=replace_with_your_app_secret
CANCEL_TOKEN_TTL_MINUTES=30
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=resend
SMTP_PASS=your_smtp_password
EMAIL_FROM=Your Store <no-reply@yourdomain.com>

# --- Local development with Mailpit (docker compose --profile dev) ---
# Uncomment the lines below and comment out the SMTP block above
# SMTP_HOST=mailpit
# SMTP_PORT=1025
# SMTP_SECURE=false
# SMTP_USER=test
# SMTP_PASS=test
# EMAIL_FROM=Your Store <no-reply@yourstore.test>
CANCEL_NOTIFY_CUSTOMER=true
CANCEL_RESTOCK=true
CANCEL_REFUND=false
ORDER_LOOKBACK_DAYS=90

# Admin panel (generate a random token: openssl rand -hex 32)
ADMIN_API_TOKEN=change_me_to_a_random_secret

# Rate limiting (per IP)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=5

# Logging (debug, info, warn, error)
LOG_LEVEL=info

# Data directory (default: ./data)
# DATA_DIR=/var/lib/shopify-cancel-app/data

# Shopify Webhooks
SHOPIFY_WEBHOOK_SECRET=replace_with_your_webhook_secret

# Reverse proxy trust — required when behind a reverse proxy / load balancer
# Accepts: 0/false (disabled), 1/true (trust one hop), or "loopback" / CIDR range
# Without this, rate limiting sees the proxy IP instead of the real client IP
# TRUST_PROXY=0

# Error monitoring (optional — install @sentry/node to enable)
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
# SENTRY_TRACES_SAMPLE_RATE=0.1

# Backup settings (used by scripts/backup-db.sh)
# BACKUP_DIR=./data/backups
# BACKUP_RETENTION_DAYS=30
